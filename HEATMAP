# fill column NaN with median 
exprs_data[is.nan(exprs_data)] <- NA

exprs_data <- apply(exprs_data, 2, function(x) {
  x[is.na(x)] <- median(x, na.rm = TRUE)
  x
})
feature_data <- feature_data[rownames(exprs_data), ]
