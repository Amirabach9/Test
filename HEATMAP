colnames(feature_data)
head(feature_data$`Gene symbol`)  # Confirm it has gene symbols

# Combine expression data and annotation
exprs_annotated <- data.frame(probe_id = rownames(exprs_data),
                              exprs_data,
                              stringsAsFactors = FALSE)

# Add gene symbols
exprs_annotated$gene_symbol <- feature_data[rownames(exprs_data), "Gene symbol"]
exprs_annotated$gene_symbol <- sapply(strsplit(exprs_annotated$gene_symbol, "///", fixed = TRUE), `[`, 1)

write.csv(exprs_annotated, "~/HYRS_bioinfo/GSE73622/GSE73622_Exprs_annotated.csv")
colnames(exprs_annotated)

dim(exprs_annotated)

exprs_matrix <- exprs_annotated
dim(exprs_matrix)

table(pheno_data$`disease:ch1`)
group <- factor(pheno_data$`disease:ch1`)
colnames(exprs_matrix)
rownames(pheno_data)
pheno_data <- pheno_data[colnames(exprs_matrix), ]

design <- model.matrix(~0 + group)
colnames(design) <- make.names(colnames(design))
contrast.matrix <- makeContrasts(
  Endometriosis_vs_Control = groupEndometriosis - groupNo.Endometriosis,
  levels = design
)

fit <- lmFit(exprs_data, design)
fit2 <- contrasts.fit(fit, contrast.matrix)
fit2 <- eBayes(fit2)

results <- topTable(fit2, adjust = "fdr", number = Inf)
dim(results)
